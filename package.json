{
  "name": "lyricslay",
  "version": "2.7.5",
  "description": "Real-time, synced lyrics overlay for YouTube Music, always on top of any application.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:publish": "electron-builder --publish always",
    "test": "node --test"
  },
  "author": "Arzatar",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.arzatar.lyricslay",
    "productName": "Lyricslay",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/nowplaying.ps1",
      "src/foregroundApp.ps1"
    ],
    "publish": {
      "provider": "github",
      "owner": "Arzatar",
      "repo": "Lyricslay",
      "releaseType": "release"
    }
  }
}
